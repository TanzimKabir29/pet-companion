# Copy this file to .env and fill in the values

# PostgreSQL
DATABASE_URL=postgres://petcompanion:petcompanion@localhost:5432/petcompanion

# JWT secret — change this to a strong random string in production
JWT_SECRET=change-me-in-production

# JWT expiration in seconds (default: 86400 = 24 hours)
JWT_EXPIRES_IN=86400

# Directory for uploaded files
UPLOAD_DIR=./uploads

# Anthropic API key — required for photo analysis feature
ANTHROPIC_API_KEY=sk-ant-...

# Server port
PORT=8080

# Log level (error, warn, info, debug, trace)
RUST_LOG=info
